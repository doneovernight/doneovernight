# Existing shared infrastructure
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
TELEGRAM_BOT_TOKEN=
HEARTBEAT_TELEGRAM_CHAT_ID=

# Content generation: use a model already approved for DONEOVERNIGHT.
OPENAI_API_KEY=
OPENAI_MODEL=

# Content agent controls
CONTENT_PUBLISH_MODE=approve
CRON_SECRET=
CONTENT_DAILY_CAP=3
CONTENT_MIN_INTERVAL_MINUTES=180
CONTENT_PUBLISH_START=08:00
CONTENT_PUBLISH_END=21:30
CONTENT_TIMEZONE=Europe/Amsterdam
CONTENT_PUBLISH_THRESHOLD=0.68
X_ALLOW_TEST_POST=false

# Preferred X OAuth 2.0 user context
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=
X_ACCESS_TOKEN=
X_REFRESH_TOKEN=

# Optional X OAuth 1.0a user context fallback
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN_SECRET=
